# Copy this file to .env and fill in your own values.

DASHSCOPE_API_KEY=your_dashscope_api_key

# Official realtime endpoint.
QWEN_REALTIME_BASE_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime

# Official latest realtime multimodal model as of 2026-04-08.
QWEN_REALTIME_MODEL=qwen3.5-omni-plus-realtime

TMK_SAMPLE_RATE=16000
TMK_CHANNELS=1
TMK_CHUNK_MILLIS=200
TMK_AUDIO_BUFFER_FRAMES=64
TMK_DEBUG=false
